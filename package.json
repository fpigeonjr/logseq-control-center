{
  "name": "logseq-control-center",
  "version": "0.1.0",
  "description": "Local dashboard for a LogSeq graph — life OS control center",
  "type": "module",
  "scripts": {
    "index": "tsx src/indexer/cli.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite src/web",
    "build": "vite build src/web --outDir ../../dist/web && tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run typecheck && npm run lint && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "chokidar": "^3.6.0",
    "hono": "^4.7.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "postcss": "^8.5.3",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.28.2",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.3.2",
    "vitest": "^4.1.5"
  }
}
